{
  "input_model": {
    "type": "OnnxModel",
    "config": {
      "model_path": "6drepnet.fp32.onnx"
    }
  },
  "passes": {
    "quantize": {
      "type": "OnnxDynamicQuantization",
      "config": {
        "per_channel": true,
        "reduce_range": false,
        "weight_type": "QInt8"
      }
    }
  },
  "engine": {
    "evaluate_input_model": false,
    "output_dir": ".",
    "output_name": "6drepnet.int8",
    "cache_dir": ".olive_cache"
  }
}
