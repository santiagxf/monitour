<?xml version="1.0" encoding="utf-8"?>
<packages>
  <!-- Microsoft Windows ML 2.x (standalone). Provides ONNX Runtime + the
       ExecutionProviderCatalog used to route inference to the Intel AI Boost
       NPU via the OpenVINO execution provider. Windows downloads/updates the
       NPU EP via Windows Update; the package itself ships the ORT C++ headers
       and import libs we build against. -->
  <package id="Microsoft.Windows.AI.MachineLearning" version="2.1.6" targetFramework="native" />
</packages>
